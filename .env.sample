# ==========================================
# Frontend Environment Variables (frontend/)
# ==========================================

# The URL of the backend API
# Update this to your production API URL when deploying (e.g., https://nexora-backend.onrender.com)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Node.js version (used by Render)
NODE_VERSION=20.11.0


# ==========================================
# Backend Environment Variables (backend/)
# ==========================================

# Database connection string
# For local SQLite: sqlite:///./nexora.db
# For PostgreSQL: postgresql://user:password@localhost:5432/nexora
DATABASE_URL=sqlite:///./nexora.db

# Python version (used by Render)
PYTHON_VERSION=3.11.4
